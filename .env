APP_NAME=SiAbsen
APP_ENV=production
APP_DEBUG=false
APP_URL=https://siabsen-production-2bdd.up.railway.app
APP_KEY=base64:ISI_KEY_KAMU

LOG_CHANNEL=stderr
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=${PGHOST}
DB_PORT=${PGPORT}
DB_DATABASE=${PGDATABASE}
DB_USERNAME=${PGUSER}
DB_PASSWORD=${PGPASSWORD}

SESSION_DRIVER=file
CACHE_STORE=file
QUEUE_CONNECTION=sync

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
MAIL_MAILER=log
TRUSTED_PROXIES=*
